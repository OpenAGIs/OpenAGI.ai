---
import Layout from '../layouts/Layout.astro';

const dailyReports = [
  {
    date: '2026-03-09',
    title: 'OpenAGI Daily Brief #001',
    summary: '完成站点多项迭代：媒体页精简、导航语言切换、搜索功能下线。'
  },
  {
    date: '2026-03-08',
    title: 'OpenAGI Daily Brief #000',
    summary: '上线 /media.html 并建立自媒体矩阵基础数据结构。'
  }
];
---

<Layout title="OpenAGI Newsletter" description="OpenAGI 日报与订阅页面。">
  <main class="container">
    <header class="hero">
      <h1>OpenAGI Newsletter</h1>
      <p>订阅 OpenAGI 每日/每周更新，集中查看日报归档与同步状态。</p>
    </header>

    <section class="panel">
      <h2>订阅入口</h2>
      <div class="subscribe-row">
        <a class="btn" href="https://openagis.substack.com" target="_blank" rel="noopener noreferrer">Substack</a>
        <a class="btn" href="/rss.xml">RSS</a>
        <a class="btn" href="https://t.me/openagi" target="_blank" rel="noopener noreferrer">Telegram</a>
      </div>
    </section>

    <section class="panel">
      <h2>日报归档（Daily Briefs）</h2>
      <div class="list">
        {dailyReports.map((item) => (
          <article class="card">
            <div class="meta">{item.date}</div>
            <h3>{item.title}</h3>
            <p>{item.summary}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="panel">
      <h2>One-to-Many 日报同步设计（预留）</h2>
      <ol>
        <li><strong>内容聚合：</strong>汇总当天网站更新、代码提交、运营动作。</li>
        <li><strong>日报生成：</strong>按统一模板生成 Newsletter 日报正文。</li>
        <li><strong>多端同步：</strong>同一份日报分发到 Newsletter 页面、Substack、Telegram、X。</li>
        <li><strong>状态回写：</strong>记录各平台同步状态（success/failed/pending）。</li>
      </ol>
      <div class="status-grid">
        <div class="status"><span>Website</span><b>ready</b></div>
        <div class="status"><span>Substack</span><b>planned</b></div>
        <div class="status"><span>Telegram</span><b>planned</b></div>
        <div class="status"><span>X</span><b>planned</b></div>
      </div>
      <p class="note">后续可接入自动任务：每日 23:00 生成并同步日报到本页面与外部渠道。</p>
    </section>
  </main>

  <style>
    .container{max-width:980px;margin:0 auto;padding:2rem 1rem 4rem}
    .hero h1{font-family:var(--font-display);font-size:clamp(2rem,4vw,3rem);background:linear-gradient(120deg,var(--primary-bright),var(--cyan-bright));-webkit-background-clip:text;-webkit-text-fill-color:transparent}
    .hero p{color:var(--text-secondary);margin-top:.5rem}
    .panel{margin-top:1.2rem;background:linear-gradient(160deg, rgba(17,24,39,.82), rgba(10,15,26,.92));border:1px solid var(--border-subtle);border-radius:14px;padding:1.1rem}
    .subscribe-row{display:flex;gap:.6rem;flex-wrap:wrap}
    .btn{border:1px solid var(--border-accent);padding:.45rem .75rem;border-radius:10px;text-decoration:none;color:var(--text-primary);background:rgba(0,212,255,.08)}
    .list{display:grid;gap:.7rem}
    .card{border:1px solid var(--border-subtle);border-radius:10px;padding:.8rem;background:rgba(255,255,255,.02)}
    .meta{color:var(--text-muted);font-size:.9rem}
    .status-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:.6rem;margin-top:.8rem}
    .status{border:1px solid var(--border-subtle);border-radius:10px;padding:.6rem;background:rgba(255,255,255,.02);display:flex;justify-content:space-between}
    .note{margin-top:.7rem;color:var(--text-muted)}
  </style>
</Layout>
