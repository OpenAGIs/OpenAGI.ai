---

<Layout title="OpenAGI Media — 自媒体矩阵与增长看板" description="OpenAGI 自媒体平台账号、粉丝与增长趋势看板。">
  <main class="container">
    <header class="hero">
      <a href="/" class="back-link">← Back to Home</a>
      <h1>OpenAGI Media</h1>
      <p>OpenAGI 自媒体矩阵、粉丝基线与增长趋势（持续更新）</p>
    </header>

    <section class="panel">
      <h2>平台账号与增长情况</h2>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>平台</th>
              <th>账号</th>
              <th>主页</th>
              <th>粉丝</th>
              <th>近7天</th>
              <th>近30天</th>
              <th>更新时间</th>
              <th>趋势</th>
            </tr>
          </thead>
          <tbody>
            {mediaAccounts.map((item) => (
              <tr>
                <td>{item.platform}</td>
                <td>{item.account}</td>
                <td><a href={item.url} target="_blank" rel="noopener noreferrer">访问</a></td>
                <td>{item.followers}</td>
                <td>{item.delta7d}</td>
                <td>{item.delta30d}</td>
                <td>{item.updatedAt}</td>
                <td>
                  <div class="actions">
                    <button class="btn btn-trend" data-platform={item.platform} data-account={item.account}>查看趋势</button>
                    <button class="btn btn-analyze" data-platform={item.platform} data-account={item.account}>趋势分析</button>
                  </div>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="note">注：当前趋势图使用 mock 数据演示交互。后续可接真实平台 API / 手工导入 CSV。</p>
    </section>

    <section class="panel">
      <h2>一端多发（One-to-Many）架构建议</h2>
      <ul>
        <li><strong>内容中心：</strong>统一母稿（标题、正文、标签、素材）</li>
        <li><strong>平台适配：</strong>按平台模板自动改写（字数、语气、话题标签、封面规格）</li>
        <li><strong>分发层：</strong>支持 API 直发 + 半自动发布（无 API 平台）</li>
        <li><strong>回流分析：</strong>归集曝光、互动、净增粉和站点点击，反哺选题策略</li>
      </ul>
      <p class="note">建议你后续提供各平台账号凭据（至少 API Key / Cookie 方案）后再启用自动分发；否则先走“半自动发布 + 自动分析”模式更稳。</p>
    </section>

    <section class="panel">
      <h2>EvoMap.ai Evolver 接入计划（自我改进与优化）</h2>
      <ul>
        <li><strong>目标：</strong>让内容策略能持续自我迭代（主题、标题、发布时间、平台组合）</li>
        <li><strong>输入：</strong>平台历史数据 + 发布记录 + 互动质量评分</li>
        <li><strong>Evolver 输出：</strong>下一轮实验建议（A/B 主题、发布时间窗、分发配比）</li>
        <li><strong>风控：</strong>设置人工审批阈值（涉及品牌风险的文案必须人工确认）</li>
      </ul>
      <div class="chips">
        <span>OpenAGI.ai</span>
        <span>OpenAGI.foundation</span>
        <span>OpenAGI.bot</span>
        <span>GEO Skills</span>
        <span>EvoMap Evolver</span>
      </div>
    </section>
  </main>

  <dialog id="trendDialog" class="trend-dialog">
    <div class="dialog-head">
      <h3 id="dialogTitle">趋势图</h3>
      <button id="closeDialog" class="btn">关闭</button>
    </div>
    <div class="chart-wrap">
      <svg id="trendSvg" viewBox="0 0 620 260" preserveAspectRatio="none" aria-label="trend chart"></svg>
    </div>
    <div id="analysisBox" class="analysis"></div>
  </dialog>

  <script>
    const trendDialog = document.getElementById('trendDialog');
    const trendSvg = document.getElementById('trendSvg');
    const dialogTitle = document.getElementById('dialogTitle');
    const analysisBox = document.getElementById('analysisBox');

    const hash = (str) => [...str].reduce((a,c)=>a + c.charCodeAt(0), 0);

    function mockSeries(seed, points = 12) {
      const arr = [];
      let current = 100 + (seed % 40);
      for (let i=0;i<points;i++) {
        const drift = ((seed + i*17) % 11) - 4;
        current = Math.max(40, current + drift);
        arr.push(current);
      }
      return arr;
    }

    function toPath(data, width=620, height=260, pad=24){
      const min = Math.min(...data), max = Math.max(...data);
      const dx = (width - pad*2) / (data.length - 1);
      const norm = v => height - pad - ((v - min) / ((max-min)||1)) * (height - pad*2);
      return data.map((v,i)=>`${i===0?'M':'L'} ${pad + i*dx} ${norm(v)}`).join(' ');
    }

    function renderChart(platform){
      const seed = hash(platform);
      const d7 = mockSeries(seed, 7);
      const d30 = mockSeries(seed + 77, 10);
      const d90 = mockSeries(seed + 199, 12);
      trendSvg.innerHTML = `
        <rect x="0" y="0" width="620" height="260" fill="rgba(8,12,22,.9)" />
        <path d="${toPath(d90)}" stroke="#0066cc" stroke-width="2" fill="none" />
        <path d="${toPath(d30)}" stroke="#00d4ff" stroke-width="2.5" fill="none" />
        <path d="${toPath(d7)}" stroke="#00ffcc" stroke-width="3" fill="none" />
        <text x="24" y="24" fill="#8892b0" font-size="12">90d</text>
        <text x="68" y="24" fill="#00d4ff" font-size="12">30d</text>
        <text x="116" y="24" fill="#00ffcc" font-size="12">7d</text>
      `;

      const trendScore = d7[d7.length-1] - d7[0];
      const status = trendScore >= 4 ? '上升明显' : trendScore >= 0 ? '平稳偏升' : '波动回落';
      analysisBox.innerHTML = `
        <p><strong>趋势判断：</strong>${status}</p>
        <p><strong>建议：</strong>下周保持 3-5 次内容发布，优先复用最近高互动主题；尝试 A/B 标题并复盘发布时间窗口。</p>
        <p><strong>动作：</strong>将该平台纳入 GEO Skills + Evolver 实验队列，按周滚动优化。</p>
      `;
    }

    document.querySelectorAll('.btn-trend, .btn-analyze').forEach(btn => {
      btn.addEventListener('click', () => {
        const platform = btn.dataset.platform || 'Platform';
        const account = btn.dataset.account || '';
        dialogTitle.textContent = `${platform} · ${account} 趋势看板`;
        renderChart(platform);
        trendDialog.showModal();
      });
    });

    document.getElementById('closeDialog')?.addEventListener('click', () => trendDialog.close());
  </script>

  <style>
    .container { max-width: 1180px; margin: 0 auto; padding: 2rem 1rem 4rem; }
    .hero h1 { font-family: var(--font-display); font-size: clamp(2rem, 4vw, 3rem); margin-top: .5rem; background: linear-gradient(120deg,var(--primary-bright),var(--cyan-bright)); -webkit-background-clip:text; -webkit-text-fill-color:transparent; }
    .hero p { color: var(--text-secondary); margin-top: .5rem; }
    .back-link { color: var(--primary-bright); text-decoration: none; }

    .panel { margin-top: 1.5rem; background: linear-gradient(160deg, rgba(17,24,39,.82), rgba(10,15,26,.92)); border: 1px solid var(--border-subtle); border-radius: 14px; padding: 1.25rem; }
    .panel h2 { font-family: var(--font-display); font-size: 1.35rem; margin-bottom: .9rem; }

    .table-wrap { overflow-x: auto; }
    table { width: 100%; border-collapse: collapse; min-width: 1060px; }
    th, td { padding: .65rem; border-bottom: 1px solid var(--border-subtle); text-align: left; vertical-align: top; }
    th { color: var(--text-secondary); font-weight: 600; }
    td a { color: var(--primary-bright); text-decoration: none; }
    td a:hover { text-decoration: underline; }

    .actions { display: flex; flex-wrap: wrap; gap: .4rem; }
    .btn { border: 1px solid var(--border-accent); background: rgba(0,212,255,.08); color: var(--text-primary); border-radius: 10px; padding: .3rem .6rem; cursor: pointer; font-size: .82rem; }
    .btn:hover { background: rgba(0,212,255,.18); }

    .note { margin-top: .8rem; color: var(--text-muted); font-size: .92rem; }
    ul { padding-left: 1.2rem; color: var(--text-secondary); }
    .chips { margin-top: .9rem; display:flex; flex-wrap:wrap; gap:.5rem; }
    .chips span { font-size:.85rem; border:1px solid var(--border-accent); border-radius:999px; padding:.25rem .7rem; color:var(--cyan-bright); background:rgba(0,212,255,.08); }

    .trend-dialog { width: min(860px, 92vw); border: 1px solid var(--border-accent); background: #0a0f1a; color: var(--text-primary); border-radius: 14px; padding: 1rem; }
    .dialog-head { display:flex; justify-content:space-between; align-items:center; margin-bottom:.8rem; }
    .chart-wrap { border:1px solid var(--border-subtle); border-radius:12px; overflow:hidden; }
    #trendSvg { width: 100%; height: 260px; display:block; }
    .analysis { margin-top:.8rem; color:var(--text-secondary); line-height:1.7; }
  </style>
</Layout>
