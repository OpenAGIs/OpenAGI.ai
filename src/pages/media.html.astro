  { platform: 'X / Twitter', account: '@openagi_ai', url: 'https://x.com/openagi_ai', followers: '待更新', delta7d: '待更新', delta30d: '待更新', updatedAt: '2026-03-09' },
  { platform: 'YouTube', account: '@OpenAGI-AI', url: 'https://youtube.com/@OpenAGI-AI', followers: '待更新', delta7d: '待更新', delta30d: '待更新', updatedAt: '2026-03-09' },
  { platform: '知乎', account: 'OpenAGI', url: 'https://zhihu.com/people/OpenAGI', followers: '待更新', delta7d: '待更新', delta30d: '待更新', updatedAt: '2026-03-09' },
  { platform: '微博', account: 'OpenAGI', url: 'https://weibo.com/', followers: '待更新', delta7d: '待更新', delta30d: '待更新', updatedAt: '2026-03-09' },
  { platform: '小红书', account: 'openagi_ai', url: 'https://www.xiaohongshu.com/', followers: '待更新', delta7d: '待更新', delta30d: '待更新', updatedAt: '2026-03-09' },
  { platform: '微信公众号', account: '开源AGI', url: 'https://mp.weixin.qq.com/', followers: '待更新', delta7d: '待更新', delta30d: '待更新', updatedAt: '2026-03-09' },
  { platform: 'TikTok', account: '@OpenAGI_AI', url: 'https://tiktok.com/@OpenAGI_AI', followers: '待更新', delta7d: '待更新', delta30d: '待更新', updatedAt: '2026-03-09' },
  { platform: 'GitHub', account: 'OpenAGIs', url: 'https://github.com/OpenAGIs', followers: '待更新', delta7d: '待更新', delta30d: '待更新', updatedAt: '2026-03-09' },
];

const evomapServices = [
  { key: 'self-evolution', issue: 'OPE-18', name: 'AI智能体自进化引擎', url: 'https://evomap.ai/market/service/cmlz4iwni000uo301q22tj4wm', credit: 14, purpose: '自我改进与策略提炼' },
  { key: 'brand-consistency', issue: 'OPE-19', name: '品牌风格一致性生成器', url: 'https://evomap.ai/market/service/cmlz4iwbd000ho301eul0rosc', credit: 12, purpose: '多平台内容口径统一' },
  { key: 'semantic-search', issue: 'OPE-20', name: '智能语义搜索', url: 'https://evomap.ai/market/service/cmlz4iwg5000mo301rwtne659', credit: 15, purpose: 'GEO 选题与关键词扩展' },
  { key: 'automation-engine', issue: 'OPE-21', name: '自动化任务执行引擎', url: 'https://evomap.ai/market/service/cmlz4iwjt000qo3011z2yxk61', credit: 10, purpose: '一端多发流水线自动化' },
  { key: 'legal-auditor', issue: 'OPE-22', name: '法律与伦理审计器', url: 'https://evomap.ai/market/service/cmm019cfs00gioc01030hecee', credit: 16, purpose: '内容发布前风险审计' },
  { key: 'multi-agent', issue: 'OPE-23', name: '多智能体编排器', url: 'https://evomap.ai/market/service/cmlzczdxn0572lc2x17cg6k4p', credit: 18, purpose: '多代理协同与任务分发' },
];

const siteHealthPages = ['/', '/media.html', '/blog', '/concepts', '/resources', '/showcase', '/pricing', '/integrations'];
---

<Layout title="OpenAGI Media — 自媒体矩阵与增长看板" description="OpenAGI 自媒体平台账号、粉丝与增长趋势看板。">
  <main class="container">
    <header class="hero">
      <a href="/" class="back-link">← Back to Home</a>
      <h1>OpenAGI Media</h1>
      <p>OpenAGI 自媒体矩阵、粉丝基线与增长趋势（持续更新）</p>
    </header>

    <section class="panel">
      <h2>平台账号与增长情况</h2>
      <div class="table-wrap">
        <table>
          <thead><tr><th>平台</th><th>账号</th><th>主页</th><th>粉丝</th><th>近7天</th><th>近30天</th><th>更新时间</th><th>趋势</th></tr></thead>
          <tbody>
            {mediaAccounts.map((item) => (
              <tr>
                <td>{item.platform}</td><td>{item.account}</td>
                <td><a href={item.url} target="_blank" rel="noopener noreferrer">访问</a></td>
                <td>{item.followers}</td><td>{item.delta7d}</td><td>{item.delta30d}</td><td>{item.updatedAt}</td>
                <td><div class="actions"><button class="btn btn-trend" data-platform={item.platform} data-account={item.account}>查看趋势</button><button class="btn btn-analyze" data-platform={item.platform} data-account={item.account}>趋势分析</button></div></td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <section class="panel">
      <h2>EvoMap 集成控制台（6项优先资产）</h2>
      <div class="cards">
        {evomapServices.map((s) => (
          <article class="card" id={s.key}>
            <h3>{s.name}</h3>
            <p>{s.purpose}</p>
            <div class="meta">Credit: {s.credit} · Issue: {s.issue}</div>
            <div class="actions">
              <a class="btn" href={s.url} target="_blank" rel="noopener noreferrer">打开服务</a>
              <button class="btn btn-queue" data-service={s.name}>加入实验队列</button>
              <button class="btn btn-template" data-service={s.name}>复制模板</button>
            </div>
          </article>
        ))}
      </div>
      <div class="queue"><strong>实验队列（Evolver）</strong><ul id="queueList"><li>暂无，点击“加入实验队列”开始。</li></ul></div>
    </section>

    <section class="panel">
      <h2>七天可落地接入路线图（执行版）</h2>
      <ol>
        <li>D1：OPE-18 自进化引擎接入，定义实验队列字段与复盘口径</li>
        <li>D2：OPE-19 风格一致性模板，建立多平台文案约束</li>
        <li>D3：OPE-20 语义搜索接入，产出选题关键词簇</li>
        <li>D4：OPE-21 自动化引擎接入，打通分发流水线步骤</li>
        <li>D5：OPE-22 审计器接入，发布前风险评级</li>
        <li>D6：OPE-23 多智能体编排接入，拆分执行角色</li>
        <li>D7：联调与复盘，回写增长指标并生成下周实验计划</li>
      </ol>
    </section>

    <section class="panel">
      <h2>一端多发（One-to-Many）执行清单</h2>
      <ol>
        <li>内容中心：统一母稿（标题、正文、素材、CTA）</li>
        <li>平台适配：按平台模板自动改写（字数、语气、标签、封面）</li>
        <li>分发策略：API 直发 + 半自动发布（无 API 平台）</li>
        <li>回流指标：曝光、互动、净增粉、站点点击</li>
        <li>Evolver 复盘：每周根据结果自动提出下一轮实验</li>
      </ol>
    </section>

    <section class="panel">
      <h2>网站体检（关键页面）</h2>
      <div class="chips">
        {siteHealthPages.map((p) => (<span>{p}</span>))}
      </div>
      <p class="note">已纳入本轮验收：首页、媒体页、博客页、概念页、资源页、定价页、集成页。</p>
    </section>

    <section class="panel">
      <h2>真实 API 联动状态</h2>
      <div class="actions" style="margin-bottom:.8rem;">
        <button class="btn" id="refreshLiveMetrics">刷新实时指标</button>
        <button class="btn" id="checkEvomap">检查 EvoMap API</button>
      </div>
      <div id="liveMetricsBox" class="note">尚未加载实时指标。</div>
      <div id="evomapStatusBox" class="note">尚未检查 EvoMap 状态。</div>
    </section>
  </main>

  <dialog id="trendDialog" class="trend-dialog">
    <div class="dialog-head"><h3 id="dialogTitle">趋势图</h3><button id="closeDialog" class="btn">关闭</button></div>
    <div class="chart-wrap"><svg id="trendSvg" viewBox="0 0 620 260" preserveAspectRatio="none"></svg></div>
    <div id="analysisBox" class="analysis"></div>
  </dialog>

  <script>
    const trendDialog = document.getElementById('trendDialog');
    const trendSvg = document.getElementById('trendSvg');
    const dialogTitle = document.getElementById('dialogTitle');
    const analysisBox = document.getElementById('analysisBox');
    const queueList = document.getElementById('queueList');

    const hash = (str) => [...str].reduce((a,c)=>a + c.charCodeAt(0), 0);
    const mockSeries = (seed, points=12) => { const arr=[]; let cur=100+(seed%40); for(let i=0;i<points;i++){ cur=Math.max(40, cur + (((seed+i*17)%11)-4)); arr.push(cur);} return arr; };
    function toPath(data,w=620,h=260,p=24){ const min=Math.min(...data),max=Math.max(...data); const dx=(w-p*2)/(data.length-1); const norm=v=>h-p-((v-min)/((max-min)||1))*(h-p*2); return data.map((v,i)=>`${i===0?'M':'L'} ${p+i*dx} ${norm(v)}`).join(' '); }

    function renderChart(platform){
      const seed = hash(platform), d7=mockSeries(seed,7), d30=mockSeries(seed+77,10), d90=mockSeries(seed+199,12);
      trendSvg.innerHTML = `<rect x="0" y="0" width="620" height="260" fill="rgba(8,12,22,.9)"/><path d="${toPath(d90)}" stroke="#0066cc" stroke-width="2" fill="none"/><path d="${toPath(d30)}" stroke="#00d4ff" stroke-width="2.5" fill="none"/><path d="${toPath(d7)}" stroke="#00ffcc" stroke-width="3" fill="none"/>`;
      const score = d7[d7.length-1]-d7[0];
      const status = score >= 4 ? '上升明显' : score >= 0 ? '平稳偏升' : '波动回落';
      analysisBox.innerHTML = `<p><strong>趋势判断：</strong>${status}</p><p><strong>建议：</strong>下周保持 3-5 次发布，复用高互动主题并做标题 A/B。</p><p><strong>Evolver动作：</strong>加入实验队列，周末自动复盘并生成下一轮策略。</p>`;
    }

    document.querySelectorAll('.btn-trend, .btn-analyze').forEach(btn => btn.addEventListener('click', () => {
      const platform = btn.dataset.platform || 'Platform';
      const account = btn.dataset.account || '';
      dialogTitle.textContent = `${platform} · ${account} 趋势看板`;
      renderChart(platform);
      trendDialog.showModal();
    }));

    document.querySelectorAll('.btn-queue').forEach(btn => btn.addEventListener('click', () => {
      const s = btn.dataset.service;
      if (queueList.children.length === 1 && queueList.textContent.includes('暂无')) queueList.innerHTML='';
      const li = document.createElement('li');
      li.textContent = `${new Date().toLocaleString()} · ${s} 已加入实验队列`;
      queueList.prepend(li);
    }));

    document.querySelectorAll('.btn-template').forEach(btn => btn.addEventListener('click', async () => {
      const s = btn.dataset.service;
      const text = `{"service":"${s}","objective":"growth-optimization","input":{"platform":"X/YouTube","window":"7d"},"output":"strategy"}`;
      try { await navigator.clipboard.writeText(text); alert('已复制执行模板'); } catch { alert(text); }
    }));

    async function loadLiveMetrics() {
      const box = document.getElementById('liveMetricsBox');
      if (!box) return;
      box.textContent = '正在拉取实时指标...';
      try {
        const res = await fetch('/api/media/metrics');
        const json = await res.json();
        if (!json?.ok) {
          box.textContent = `加载失败：${json?.error || 'unknown error'}`;
          return;
        }
        const rows = (json.metrics || [])
          .map((m) => `${m.platform} / ${m.account}：${m.followers ?? 'N/A'}（${m.source}）`)
          .join(' | ');
        box.textContent = `更新时间 ${new Date(json.generatedAt).toLocaleString()} · ${rows}`;
      } catch (e) {
        box.textContent = `加载失败：${e instanceof Error ? e.message : String(e)}`;
      }
    }

    async function checkEvomapApi() {
      const box = document.getElementById('evomapStatusBox');
      if (!box) return;
      box.textContent = '正在检查 EvoMap API...';
      try {
        const res = await fetch('/api/evomap/status');
        const json = await res.json();
        box.textContent = `EvoMap: ok=${json.ok} status=${json.status ?? 'n/a'} body=${(json.body || '').slice(0, 120)}`;
      } catch (e) {
        box.textContent = `检查失败：${e instanceof Error ? e.message : String(e)}`;
      }
    }

    document.getElementById('refreshLiveMetrics')?.addEventListener('click', loadLiveMetrics);
    document.getElementById('checkEvomap')?.addEventListener('click', checkEvomapApi);

    void loadLiveMetrics();

    document.getElementById('closeDialog')?.addEventListener('click', () => trendDialog.close());
  </script>

  <style>
    .container{max-width:1180px;margin:0 auto;padding:2rem 1rem 4rem}.hero h1{font-family:var(--font-display);font-size:clamp(2rem,4vw,3rem);margin-top:.5rem;background:linear-gradient(120deg,var(--primary-bright),var(--cyan-bright));-webkit-background-clip:text;-webkit-text-fill-color:transparent}.hero p{color:var(--text-secondary)}.back-link{color:var(--primary-bright);text-decoration:none}
    .panel{margin-top:1.5rem;background:linear-gradient(160deg,rgba(17,24,39,.82),rgba(10,15,26,.92));border:1px solid var(--border-subtle);border-radius:14px;padding:1.25rem}.panel h2{font-family:var(--font-display);font-size:1.35rem;margin-bottom:.9rem}
    .table-wrap{overflow-x:auto} table{width:100%;border-collapse:collapse;min-width:1060px} th,td{padding:.65rem;border-bottom:1px solid var(--border-subtle);text-align:left;vertical-align:top} td a{color:var(--primary-bright)}
    .actions{display:flex;flex-wrap:wrap;gap:.4rem}.btn{border:1px solid var(--border-accent);background:rgba(0,212,255,.08);color:var(--text-primary);border-radius:10px;padding:.3rem .6rem;cursor:pointer;font-size:.82rem;text-decoration:none}.btn:hover{background:rgba(0,212,255,.18)}
    .cards{display:grid;grid-template-columns:repeat(auto-fit,minmax(230px,1fr));gap:.8rem}.card{border:1px solid var(--border-subtle);border-radius:12px;padding:.8rem;background:rgba(11,17,28,.6)}.card h3{margin:0 0 .4rem}.card p{margin:0 0 .4rem;color:var(--text-secondary)}.meta{font-size:.85rem;color:var(--text-muted);margin-bottom:.5rem}
    .queue{margin-top:.8rem;border:1px dashed var(--border-accent);border-radius:10px;padding:.8rem}.queue ul{margin:.5rem 0 0 1.1rem;color:var(--text-secondary)}
    .chips{display:flex;flex-wrap:wrap;gap:.5rem}.chips span{font-size:.85rem;border:1px solid var(--border-accent);border-radius:999px;padding:.25rem .7rem;color:var(--cyan-bright);background:rgba(0,212,255,.08)}
    .trend-dialog{width:min(860px,92vw);border:1px solid var(--border-accent);background:#0a0f1a;color:var(--text-primary);border-radius:14px;padding:1rem}.dialog-head{display:flex;justify-content:space-between;align-items:center;margin-bottom:.8rem}.chart-wrap{border:1px solid var(--border-subtle);border-radius:12px;overflow:hidden}#trendSvg{width:100%;height:260px;display:block}.analysis{margin-top:.8rem;color:var(--text-secondary);line-height:1.7}
  </style>
</Layout>
