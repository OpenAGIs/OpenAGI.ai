---
import Layout from '../layouts/Layout.astro';

const mediaAccounts = [
  { platform: 'X / Twitter', account: '@openagi_ai', url: 'https://x.com/openagi_ai', followers: '待更新', delta7d: '待更新', delta30d: '待更新', updatedAt: '2026-03-09' },
  { platform: 'YouTube', account: '@OpenAGI-AI', url: 'https://youtube.com/@OpenAGI-AI', followers: '待更新', delta7d: '待更新', delta30d: '待更新', updatedAt: '2026-03-09' },
  { platform: '知乎', account: 'OpenAGI', url: 'https://zhihu.com/people/OpenAGI', followers: '待更新', delta7d: '待更新', delta30d: '待更新', updatedAt: '2026-03-09' },
  { platform: '微博', account: 'OpenAGI', url: 'https://weibo.com/', followers: '待更新', delta7d: '待更新', delta30d: '待更新', updatedAt: '2026-03-09' },
  { platform: '小红书', account: 'openagi_ai', url: 'https://www.xiaohongshu.com/', followers: '待更新', delta7d: '待更新', delta30d: '待更新', updatedAt: '2026-03-09' },
  { platform: '微信公众号', account: '开源AGI', url: 'https://mp.weixin.qq.com/', followers: '待更新', delta7d: '待更新', delta30d: '待更新', updatedAt: '2026-03-09' },
  { platform: 'TikTok', account: '@OpenAGI_AI', url: 'https://tiktok.com/@OpenAGI_AI', followers: '待更新', delta7d: '待更新', delta30d: '待更新', updatedAt: '2026-03-09' },
  { platform: 'LinkedIn', account: 'openagi', url: 'https://linkedin.com/in/openagi', followers: '待更新', delta7d: '待更新', delta30d: '待更新', updatedAt: '2026-03-09' },
  { platform: 'GitHub', account: 'OpenAGIs', url: 'https://github.com/OpenAGIs', followers: '待更新', delta7d: '待更新', delta30d: '待更新', updatedAt: '2026-03-09' },
  { platform: 'Instagram', account: 'OpenAGI-AI', url: 'https://instagram.com/OpenAGI-AI', followers: '待更新', delta7d: '待更新', delta30d: '待更新', updatedAt: '2026-03-09' },
  { platform: 'Threads', account: 'OpenAGI-AI', url: 'https://www.threads.net/', followers: '待更新', delta7d: '待更新', delta30d: '待更新', updatedAt: '2026-03-09' },
  { platform: 'Substack', account: 'OpenAGIs', url: 'https://openagis.substack.com', followers: '待更新', delta7d: '待更新', delta30d: '待更新', updatedAt: '2026-03-09' },
  { platform: 'Facebook', account: 'openagiai', url: 'https://www.facebook.com/openagiai', followers: '待更新', delta7d: '待更新', delta30d: '待更新', updatedAt: '2026-03-09' },
];
---

<Layout title="OpenAGI Media — 自媒体矩阵" description="OpenAGI 自媒体平台账号信息与增长记录。">
  <main class="container">
    <header class="hero">
      <a href="/" class="back-link">← Back to Home</a>
      <h1>OpenAGI 自媒体矩阵</h1>
      <p>仅保留 OpenAGI 自媒体平台账号与数据记录。</p>
    </header>

    <section class="panel">
      <h2>平台账号与增长数据</h2>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>平台</th>
              <th>账号</th>
              <th>主页</th>
              <th>粉丝</th>
              <th>近7天</th>
              <th>近30天</th>
              <th>更新时间</th>
            </tr>
          </thead>
          <tbody>
            {mediaAccounts.map((item) => (
              <tr>
                <td>{item.platform}</td>
                <td>{item.account}</td>
                <td><a href={item.url} target="_blank" rel="noopener noreferrer">访问</a></td>
                <td>{item.followers}</td>
                <td>{item.delta7d}</td>
                <td>{item.delta30d}</td>
                <td>{item.updatedAt}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="note">说明：本页仅展示 OpenAGI 自媒体矩阵信息，其他模块已移除。</p>
    </section>
  </main>

  <style>
    .container { max-width: 1100px; margin: 0 auto; padding: 2rem 1rem 4rem; }
    .hero h1 {
      font-family: var(--font-display);
      font-size: clamp(2rem, 4vw, 3rem);
      margin-top: .5rem;
      background: linear-gradient(120deg, var(--primary-bright), var(--cyan-bright));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
    }
    .hero p { color: var(--text-secondary); margin-top: .5rem; }
    .back-link { color: var(--primary-bright); text-decoration: none; }

    .panel {
      margin-top: 1.2rem;
      background: linear-gradient(160deg, rgba(17,24,39,.82), rgba(10,15,26,.92));
      border: 1px solid var(--border-subtle);
      border-radius: 14px;
      padding: 1.2rem;
    }
    .panel h2 { font-family: var(--font-display); margin-bottom: .8rem; }

    .table-wrap { overflow-x: auto; }
    table { width: 100%; border-collapse: collapse; min-width: 860px; }
    th, td {
      padding: .65rem;
      border-bottom: 1px solid var(--border-subtle);
      text-align: left;
    }
    td a { color: var(--primary-bright); text-decoration: none; }
    td a:hover { text-decoration: underline; }

    .note { margin-top: .8rem; color: var(--text-muted); font-size: .92rem; }
  </style>
</Layout>
