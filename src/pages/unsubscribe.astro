---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Unsubscribe">
  <main class="content">
    <h1>Unsubscribe</h1>
    <p>
      To unsubscribe from OpenAGI emails, reply to the email you received or contact
      <a href="mailto:community@openagi.ai">community@openagi.ai</a>.
    </p>
  </main>
</Layout>

<style>
  .content {
    max-width: 720px;
    margin: 0 auto;
    padding: 48px 16px;
  }
</style>

