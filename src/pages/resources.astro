---
import Layout from '../layouts/Layout.astro';
import { resources } from '../data/resources';

const allTags = Array.from(new Set(resources.flatMap((r) => r.tags))).sort();
---

<Layout title="AI Resource Directory — OpenAGI" description="Card-based directory for AI resources, frameworks, tools, and community members with tag filters.">
  <div class="stars"></div>
  <div class="nebula"></div>

  <main class="container">
    <header class="hero">
      <a href="/" class="back-link">← Back to home</a>
      <p class="eyebrow">Community · Resources</p>
      <h1>
        <span class="claw-accent">⟩</span> AI Resource & Alumni Directory
      </h1>
      <p class="lede">
        Browse community-built tools, runtimes, and programs. Filter by tags like Framework, LLM, Agentic Workflow, or People.
      </p>
      <div class="tags" id="tag-filters">
        <button class="tag-chip active" data-tag="all">All</button>
        {allTags.map((tag) => (
          <button class="tag-chip" data-tag={tag}>{tag}</button>
        ))}
      </div>
    </header>

    <section class="grid" id="resource-grid">
      {resources.map((resource) => (
        <article class="card" id={resource.id} data-tags={resource.tags.join(',')}>
          <div class="card-top">
            <div class="logo">
              {resource.logo ? (
                <img class="logo-img" src={resource.logo} alt={`${resource.name} logo`} loading="lazy" />
              ) : (
                resource.name.charAt(0)
              )}
            </div>
            <div class="meta">
              <p class="owner">{resource.owner}</p>
              <div class="badges">
                {resource.tags.map((tag) => (
                  <span class="badge">{tag}</span>
                ))}
              </div>
            </div>
          </div>
          <h2>{resource.name}</h2>
          <p class="desc">{resource.description}</p>
          <a href={resource.link} target="_blank" rel="noopener" class="cta">Visit →</a>
        </article>
      ))}
    </section>
  </main>
</Layout>

<script>
  const tagButtons = Array.from(document.querySelectorAll('.tag-chip'));
  const cards = Array.from(document.querySelectorAll('.card'));

  const filter = (tag) => {
    cards.forEach((card) => {
      const tags = card.dataset.tags.split(',');
      const show = tag === 'all' || tags.includes(tag);
      card.style.display = show ? 'flex' : 'none';
    });
  };

  tagButtons.forEach((btn) => {
    btn.addEventListener('click', () => {
      tagButtons.forEach((b) => b.classList.remove('active'));
      btn.classList.add('active');
      filter(btn.dataset.tag);
    });
  });
</script>

<style>
  .stars {
    position: fixed;
    inset: 0;
    background-image:
      radial-gradient(1px 1px at 30% 20%, rgba(255,255,255,0.6), transparent),
      radial-gradient(1px 1px at 70% 40%, rgba(0,255,204,0.5), transparent),
      radial-gradient(1px 1px at 20% 70%, rgba(0,153,255,0.4), transparent),
      radial-gradient(1px 1px at 80% 80%, rgba(255,255,255,0.4), transparent);
    background-size: 500px 500px;
    animation: twinkle 10s ease-in-out infinite alternate;
    pointer-events: none;
    z-index: 0;
  }

  @keyframes twinkle {
    from { opacity: 0.4; }
    to { opacity: 0.8; }
  }

  .nebula {
    position: fixed;
    inset: 0;
    background:
      radial-gradient(ellipse 80% 50% at 20% 20%, rgba(0, 212, 255, 0.12), transparent 50%),
      radial-gradient(ellipse 50% 60% at 80% 30%, rgba(255, 77, 77, 0.08), transparent 50%),
      radial-gradient(ellipse 90% 70% at 50% 90%, rgba(0, 229, 204, 0.05), transparent 50%);
    pointer-events: none;
    z-index: 0;
  }

  .container {
    position: relative;
    z-index: 1;
    max-width: 1200px;
    margin: 0 auto;
    padding: 40px 24px 64px;
  }

  .hero {
    margin-bottom: 24px;
  }

  .back-link {
    display: inline-block;
    margin-bottom: 12px;
    color: var(--text-muted);
    text-decoration: none;
  }

  .back-link:hover { color: var(--primary-bright); }

  .eyebrow {
    font-size: 0.9rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--text-secondary);
    margin-bottom: 8px;
  }

  .hero h1 {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 3rem);
    margin-bottom: 8px;
  }

  .claw-accent { color: var(--primary-bright); }

  .lede {
    color: var(--text-secondary);
    max-width: 720px;
    margin-bottom: 14px;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .tag-chip {
    padding: 8px 12px;
    border-radius: 999px;
    border: 1px solid var(--border-subtle);
    background: rgba(255,255,255,0.02);
    color: var(--text-primary);
    cursor: pointer;
    transition: all 0.2s ease;
    font-weight: 600;
  }

  .tag-chip:hover { border-color: var(--primary-bright); }

  .tag-chip.active {
    background: linear-gradient(90deg, var(--primary-dark), var(--primary-bright));
    color: #02121c;
    border-color: var(--primary-mid);
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 16px;
    margin-top: 20px;
  }

  .card {
    display: flex;
    flex-direction: column;
    gap: 10px;
    padding: 18px;
    border: 1px solid var(--border-subtle);
    border-radius: 14px;
    background: rgba(0, 0, 0, 0.25);
    box-shadow: 0 15px 30px rgba(0, 0, 0, 0.2);
    transition: transform 0.2s ease, border-color 0.2s ease;
  }

  .card:hover {
    transform: translateY(-3px);
    border-color: var(--primary-bright);
  }

  .card-top {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .logo {
    width: 46px;
    height: 46px;
    border-radius: 12px;
    display: grid;
    place-items: center;
    background: linear-gradient(135deg, rgba(0, 229, 204, 0.25), rgba(0, 153, 255, 0.2));
    font-weight: 800;
    color: var(--primary-bright);
    border: 1px solid var(--border-accent);
    overflow: hidden;
  }

  .logo-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .meta { flex: 1; }

  .owner {
    color: var(--text-secondary);
    font-size: 0.95rem;
    margin-bottom: 4px;
  }

  .badges {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
  }

  .badge {
    display: inline-flex;
    padding: 4px 8px;
    border-radius: 8px;
    background: rgba(0, 229, 204, 0.1);
    color: var(--primary-bright);
    font-weight: 700;
    font-size: 0.85rem;
  }

  .card h2 {
    font-size: 1.2rem;
  }

  .desc {
    color: var(--text-secondary);
    flex: 1;
  }

  .cta {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: var(--primary-bright);
    text-decoration: none;
    font-weight: 700;
  }
</style>
