{
  "redirects": [
    {
      "source": "/(.*)",
      "destination": "https://openagi.ai/$1",
      "permanent": true,
      "has": [
        {
          "type": "host",
          "value": "clawd.bot"
        }
      ]
    },
    {
      "source": "/(.*)",
      "destination": "https://openagi.ai/$1",
      "permanent": true,
      "has": [
        {
          "type": "host",
          "value": "www.clawd.bot"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/webhooks/stripe",
      "destination": "/api/stripe-webhook"
    }
  ]
}
