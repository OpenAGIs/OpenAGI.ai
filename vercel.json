{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "astro",
  "installCommand": "npm ci",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/**/*.ts": {
      "runtime": "nodejs20.x"
    }
  },
  "redirects": [
    {
      "source": "/(.*)",
      "destination": "https://openagi.ai/$1",
      "permanent": true,
      "has": [
        {
          "type": "host",
          "value": "clawd.bot"
        }
      ]
    },
    {
      "source": "/(.*)",
      "destination": "https://openagi.ai/$1",
      "permanent": true,
      "has": [
        {
          "type": "host",
          "value": "www.clawd.bot"
        }
      ]
    }
  ]
}
